# Copy to .env and fill. NEVER commit .env.
# Google Drive (client source folder) — service-account auth for headless ingestion.
# Share the client's Drive folder with the service account's client_email, then fill below.
GOOGLE_APPLICATION_CREDENTIALS=        # path to service-account JSON, NOT the JSON itself
DRIVE_FOLDER_ID=                       # the client's shared Drive folder id
CLIENT_ID=                             # THIS run's client slug — must match a row in seeds/dim_client.csv (no silent default; unset = script/notebook error)
# Storage + compute = Microsoft Fabric / OneLake (ADR-008, supersedes ADR-005's S3).
# No S3/AWS, no MinIO, no Snowflake. Bronze/Silver run in Fabric notebooks; Gold = Warehouse views.
FABRIC_WORKSPACE=creative-intel-ws     # OneLake workspace name (abfss://<workspace>@onelake...)
FABRIC_LAKEHOUSE=creative_intel_lh     # Lakehouse name (<lakehouse>.Lakehouse/Files|Tables)
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PROMPT_VERSION=v1
